# Cognito federated identity provider (Google / Facebook / SAML / OIDC / SignInWithApple).
# Provider SECRETS (client_secret for OIDC, private_key for SignInWithApple) are NEVER
# inlined here — they live in the operator's vault and are populated at cutover via
# `aws cognito-idp update-identity-provider` from a secure file (see
# cutover-checklist-data-plane.md). Placeholders below get overwritten lifecycle-ignored.

resource "aws_cognito_identity_provider" "{{slug}}" {
  user_pool_id  = aws_cognito_user_pool.{{pool_slug}}.id
  provider_name = "{{provider_name}}"
  provider_type = "{{provider_type}}"

  provider_details = {
    {{#provider_details}}
    "{{detail_key}}" = "{{detail_value_parameterized}}"
    {{/provider_details}}
    # Sensitive fields (client_secret, private_key, SAMLMetadataFile) are populated
    # at cutover via aws cognito-idp update-identity-provider — see data-plane runbook.
  }

  attribute_mapping = {
    {{#attribute_mappings}}
    "{{cognito_attribute}}" = "{{idp_attribute}}"
    {{/attribute_mappings}}
  }

  idp_identifiers = {{idp_identifiers}}

  lifecycle {
    ignore_changes = [
      # Sensitive provider_details entries are populated out-of-band.
      provider_details,
    ]
  }
}
