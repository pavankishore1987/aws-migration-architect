# Cognito user pool app client. Client SECRETS (when generate_secret=true) are
# regenerated by AWS on creation and CANNOT be migrated — the client secret in
# the target pool will differ from source. Any downstream app holding the source
# secret must be updated at cutover (see hardcoded-values.json).

resource "aws_cognito_user_pool_client" "{{slug}}" {
  name         = "{{name}}"
  user_pool_id = aws_cognito_user_pool.{{pool_slug}}.id

  generate_secret                      = {{generate_secret}}
  refresh_token_validity               = {{refresh_token_validity}}
  access_token_validity                = {{access_token_validity}}
  id_token_validity                    = {{id_token_validity}}
  enable_token_revocation              = {{enable_token_revocation}}
  prevent_user_existence_errors        = "{{prevent_user_existence_errors}}"
  enable_propagate_additional_user_context_data = {{enable_propagate_additional_user_context_data}}

  token_validity_units {
    access_token  = "{{access_token_unit}}"
    id_token      = "{{id_token_unit}}"
    refresh_token = "{{refresh_token_unit}}"
  }

  explicit_auth_flows = {{explicit_auth_flows}}

  {{#has_oauth}}
  allowed_oauth_flows                  = {{allowed_oauth_flows}}
  allowed_oauth_flows_user_pool_client = {{allowed_oauth_flows_user_pool_client}}
  allowed_oauth_scopes                 = {{allowed_oauth_scopes}}
  callback_urls                        = {{callback_urls_parameterized}}
  logout_urls                          = {{logout_urls_parameterized}}
  default_redirect_uri                 = "{{default_redirect_uri}}"
  supported_identity_providers         = {{supported_identity_providers}}
  {{/has_oauth}}

  read_attributes  = {{read_attributes}}
  write_attributes = {{write_attributes}}

  lifecycle {
    ignore_changes = [
      # Client secret is server-generated; do not let TF churn it.
      generate_secret,
    ]
  }
}
