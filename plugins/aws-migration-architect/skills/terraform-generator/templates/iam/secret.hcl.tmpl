# Secrets Manager: this resource creates the secret CONTAINER (name, description, KMS, tags).
# The secret VALUE is NEVER inlined — values are populated separately during cutover
# (manual put-secret-value or out-of-band script reading from a secure source).
# See cutover-checklist.md for per-secret value re-population steps.

resource "aws_secretsmanager_secret" "{{slug}}" {
  name        = "{{name}}"
  description = "{{description}}"
  kms_key_id  = {{kms_alias_var secret_kms_alias}}

  recovery_window_in_days = {{recovery_window_in_days}}

  tags = merge(var.common_tags, {{tags}}, {
    Name      = "{{name}}"
    SourceArn = "{{source_arn}}"
    NEEDS_VALUE_REPOPULATION = "true"
  })

  lifecycle {
    # Once a value is populated, do not let Terraform revert it on subsequent applies.
    ignore_changes = [tags["NEEDS_VALUE_REPOPULATION"]]
  }
}

# Initial version with a PLACEHOLDER value.
# Replace via: aws secretsmanager put-secret-value --secret-id "{{name}}" --secret-string ... --profile $MIGRATION_TARGET_PROFILE
resource "aws_secretsmanager_secret_version" "{{slug}}_initial" {
  secret_id     = aws_secretsmanager_secret.{{slug}}.id
  secret_string = "PLACEHOLDER_REPLACE_DURING_CUTOVER"

  lifecycle {
    ignore_changes = [secret_string]
  }
}

{{#has_resource_policy}}
resource "aws_secretsmanager_secret_policy" "{{slug}}" {
  secret_arn = aws_secretsmanager_secret.{{slug}}.arn
  policy = jsonencode({{resource_policy_parameterized}})
}
{{/has_resource_policy}}
