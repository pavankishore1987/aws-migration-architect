resource "aws_iam_role" "{{slug}}" {
  name = "{{name}}"
  path = "{{path}}"
  description = "{{description}}"

  # Trust policy with source-account references rewritten to target.
  # NOTE: if this role had a cross-account / OIDC / IRSA / SAML trust,
  # see dependency-graph.iam_trusts and the manual_review_required block
  # in hardcoded-values.json — those trusts need explicit target-side config.
  assume_role_policy = jsonencode({{assume_role_policy_parameterized}})

  max_session_duration = {{max_session_duration}}
  permissions_boundary = {{#permissions_boundary}}{{ref:permissions_boundary_arn}}{{/permissions_boundary}}{{^permissions_boundary}}null{{/permissions_boundary}}

  tags = merge(var.common_tags, {{tags}}, {
    Name      = "{{name}}"
    SourceArn = "{{source_arn}}"
  })
}

{{#attached_managed_policies}}
resource "aws_iam_role_policy_attachment" "{{slug}}_managed_{{policy_index}}" {
  role       = aws_iam_role.{{slug}}.name
  policy_arn = "{{managed_policy_arn}}"
}
{{/attached_managed_policies}}

{{#inline_policies}}
resource "aws_iam_role_policy" "{{slug}}_inline_{{policy_index}}" {
  name = "{{inline_policy_name}}"
  role = aws_iam_role.{{slug}}.id
  policy = jsonencode({{inline_policy_parameterized}})
}
{{/inline_policies}}

{{#has_instance_profile}}
resource "aws_iam_instance_profile" "{{slug}}" {
  name = "{{name}}"
  role = aws_iam_role.{{slug}}.name
  tags = merge(var.common_tags, {{tags}})
}
{{/has_instance_profile}}
