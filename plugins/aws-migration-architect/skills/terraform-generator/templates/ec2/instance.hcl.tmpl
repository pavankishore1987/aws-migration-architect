resource "aws_instance" "{{slug}}" {
  # AMI: source AMI must be shared cross-account before apply.
  # See cutover-checklist.md for the modify-image-attribute command.
  ami           = var.ami_{{slug}}
  instance_type = "{{instance_type}}"

  subnet_id              = {{ref:subnet_arn}}
  vpc_security_group_ids = [{{#security_group_refs}}{{ref:sg_arn}},{{/security_group_refs}}]
  iam_instance_profile   = {{ref:instance_profile_arn}}
  key_name               = var.key_name_{{slug}}

  associate_public_ip_address = {{associate_public_ip_address}}
  ebs_optimized               = {{ebs_optimized}}
  monitoring                  = {{monitoring}}

  root_block_device {
    volume_type = "{{root_volume_type}}"
    volume_size = {{root_volume_size}}
    encrypted   = {{root_encrypted}}
    {{#root_kms_key_id}}kms_key_id = {{kms_alias_var root_kms_alias}}{{/root_kms_key_id}}
  }

  metadata_options {
    http_endpoint               = "enabled"
    http_tokens                 = "required"
    http_put_response_hop_limit = 1
  }

  tags = merge(var.common_tags, {{tags}}, {
    Name        = "{{name}}"
    MigratedAt  = formatdate("YYYY-MM-DD", timestamp())
    SourceArn   = "{{source_arn}}"
  })

  lifecycle {
    ignore_changes = [
      # User-data and AMI ID may be updated outside Terraform during cutover testing.
      user_data,
      ami,
    ]
  }
}
