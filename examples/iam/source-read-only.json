{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "MigrationReadOnlyDiscovery",
      "Effect": "Allow",
      "Action": [
        "ec2:Describe*",
        "ec2:Get*",
        "vpc:Describe*",
        "elasticloadbalancing:Describe*",
        "autoscaling:Describe*",
        "s3:List*",
        "s3:GetBucket*",
        "s3:GetObjectTagging",
        "s3:GetAccelerateConfiguration",
        "s3:GetLifecycleConfiguration",
        "s3:GetReplicationConfiguration",
        "s3:GetEncryptionConfiguration",
        "rds:Describe*",
        "rds:List*",
        "lambda:List*",
        "lambda:GetFunction",
        "lambda:GetFunctionConfiguration",
        "lambda:GetPolicy",
        "lambda:GetLayerVersion",
        "lambda:GetEventSourceMapping",
        "iam:List*",
        "iam:Get*",
        "iam:SimulatePrincipalPolicy",
        "iam:SimulateCustomPolicy",
        "route53:List*",
        "route53:Get*",
        "route53resolver:List*",
        "route53resolver:Get*",
        "acm:List*",
        "acm:Describe*",
        "kms:List*",
        "kms:Describe*",
        "kms:GetKeyPolicy",
        "kms:GetKeyRotationStatus",
        "secretsmanager:List*",
        "secretsmanager:DescribeSecret",
        "ssm:DescribeParameters",
        "cloudwatch:Describe*",
        "cloudwatch:List*",
        "cloudwatch:GetMetricData",
        "logs:Describe*",
        "logs:List*",
        "apigateway:GET",
        "dynamodb:Describe*",
        "dynamodb:List*",
        "cloudfront:List*",
        "cloudfront:Get*",
        "ecs:Describe*",
        "ecs:List*",
        "eks:Describe*",
        "eks:List*",
        "ecr:Describe*",
        "ecr:List*",
        "ecr:GetRepositoryPolicy",
        "ecr:GetLifecyclePolicy",
        "sns:List*",
        "sns:Get*",
        "sqs:List*",
        "sqs:GetQueueAttributes",
        "sqs:GetQueueUrl",
        "events:List*",
        "events:Describe*",
        "states:List*",
        "states:Describe*",
        "efs:Describe*",
        "fsx:Describe*",
        "elasticache:Describe*",
        "elasticache:List*",
        "es:Describe*",
        "es:List*",
        "resource-explorer-2:List*",
        "resource-explorer-2:Get*",
        "resource-explorer-2:Search",
        "config:Describe*",
        "config:Get*",
        "config:List*",
        "config:SelectResourceConfig",
        "config:GetResourceConfigHistory",
        "tag:GetResources",
        "tag:GetTagKeys",
        "tag:GetTagValues",
        "sts:GetCallerIdentity",
        "cloudformation:Describe*",
        "cloudformation:List*",
        "cloudformation:GetTemplate",
        "ce:GetCostAndUsage",
        "ce:GetReservationCoverage",
        "ce:GetReservationUtilization",
        "ce:GetSavingsPlansCoverage",
        "ce:GetSavingsPlansUtilization"
      ],
      "Resource": "*"
    },
    {
      "Sid": "ExplicitlyDenySecretValueAccess",
      "Effect": "Deny",
      "Action": [
        "secretsmanager:GetSecretValue",
        "secretsmanager:GetRandomPassword",
        "ssm:GetParameter",
        "ssm:GetParameters",
        "ssm:GetParametersByPath"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "ssm:ParameterType": "SecureString"
        }
      }
    },
    {
      "Sid": "AllowNonSecureSSMParameterReads",
      "Effect": "Allow",
      "Action": [
        "ssm:GetParameter",
        "ssm:GetParameters",
        "ssm:GetParametersByPath"
      ],
      "Resource": "*",
      "Condition": {
        "StringNotEquals": {
          "ssm:ParameterType": "SecureString"
        }
      }
    }
  ]
}
