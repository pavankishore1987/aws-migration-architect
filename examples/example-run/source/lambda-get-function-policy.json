{
  "orders-api-handler": {
    "Policy": {
      "Version": "2012-10-17",
      "Id": "default",
      "Statement": [
        {
          "Sid": "apigw-invoke",
          "Effect": "Allow",
          "Principal": { "Service": "apigateway.amazonaws.com" },
          "Action": "lambda:InvokeFunction",
          "Resource": "arn:aws:lambda:us-east-1:111111111111:function:orders-api-handler",
          "Condition": {
            "ArnLike": {
              "AWS:SourceArn": "arn:aws:execute-api:us-east-1:111111111111:abcd1234/*/*/orders"
            }
          }
        }
      ]
    }
  },
  "orders-stream-processor": {
    "Policy": null,
    "note": "No resource-based policy; invoked via event source mapping from Kinesis."
  }
}
