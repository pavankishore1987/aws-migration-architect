{
  "Clusters": [
    {
      "Name": "orders-session-cache",
      "ARN": "arn:aws:memorydb:us-east-1:111111111111:cluster/orders-session-cache",
      "Description": "Session-token cache for orders-api. Ephemeral; recreated empty in target.",
      "Status": "available",
      "NodeType": "db.r6g.large",
      "NumberOfShards": 2,
      "NumberOfReplicasPerShard": 1,
      "EngineVersion": "7.1",
