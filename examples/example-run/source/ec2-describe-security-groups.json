{
  "SecurityGroups": [
    {
      "GroupId": "sg-alb-orders",
      "GroupName": "orders-alb-sg",
      "Description": "Ingress 443 from internet to orders ALB",
      "VpcId": "vpc-0a1b2c3d4e5f6789a",
      "IpPermissions": [
        {
          "IpProtocol": "tcp",
          "FromPort": 443,
          "ToPort": 443,
          "IpRanges": [{ "CidrIp": "0.0.0.0/0", "Description": "public https" }]
        }
      ],
      "IpPermissionsEgress": [
        { "IpProtocol": "-1", "IpRanges": [{ "CidrIp": "0.0.0.0/0" }] }
      ],
      "Tags": [
        { "Key": "Name", "Value": "orders-alb-sg" },
        { "Key": "Project", "Value": "orders-api" },
        { "Key": "Team", "Value": "platform" }
      ]
    },
    {
      "GroupId": "sg-ec2-app",
      "GroupName": "orders-app-sg",
      "Description": "App servers: ingress from ALB",
      "VpcId": "vpc-0a1b2c3d4e5f6789a",
      "IpPermissions": [
        {
          "IpProtocol": "tcp",
          "FromPort": 8080,
          "ToPort": 8080,
          "UserIdGroupPairs": [{ "GroupId": "sg-alb-orders", "Description": "from ALB" }]
        }
      ],
      "IpPermissionsEgress": [
        { "IpProtocol": "-1", "IpRanges": [{ "CidrIp": "0.0.0.0/0" }] }
      ],
      "Tags": [
        { "Key": "Name", "Value": "orders-app-sg" },
        { "Key": "Project", "Value": "orders-api" },
        { "Key": "Team", "Value": "platform" }
      ]
    },
    {
      "GroupId": "sg-lambda-orders",
      "GroupName": "orders-lambda-sg",
      "Description": "Lambda ENI egress to RDS",
      "VpcId": "vpc-0a1b2c3d4e5f6789a",
      "IpPermissions": [],
      "IpPermissionsEgress": [
        { "IpProtocol": "-1", "IpRanges": [{ "CidrIp": "0.0.0.0/0" }] }
      ],
      "Tags": [
        { "Key": "Name", "Value": "orders-lambda-sg" },
        { "Key": "Project", "Value": "orders-api" },
        { "Key": "Team", "Value": "platform" }
      ]
    },
    {
      "GroupId": "sg-rds-orders",
      "GroupName": "orders-rds-sg",
      "Description": "RDS: ingress 5432 from app + lambda SGs",
      "VpcId": "vpc-0a1b2c3d4e5f6789a",
      "IpPermissions": [
        {
          "IpProtocol": "tcp",
          "FromPort": 5432,
          "ToPort": 5432,
          "UserIdGroupPairs": [
            { "GroupId": "sg-ec2-app", "Description": "from app servers" },
            { "GroupId": "sg-lambda-orders", "Description": "from order lambdas" }
          ]
        }
      ],
      "IpPermissionsEgress": [
        { "IpProtocol": "-1", "IpRanges": [{ "CidrIp": "0.0.0.0/0" }] }
      ],
      "Tags": [
        { "Key": "Name", "Value": "orders-rds-sg" },
        { "Key": "Project", "Value": "orders-api" },
        { "Key": "Team", "Value": "platform" }
      ]
    }
  ]
}
